{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://limecloud.github.io/agentqc/schemas/qc-case.schema.json",
  "title": "Agent QC Case",
  "type": "object",
  "required": [
    "id",
    "project_profile",
    "target",
    "steps",
    "expected",
    "required_evidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "name": {
      "type": "string"
    },
    "project_profile": {
      "enum": [
        "agent-runtime-cli",
        "agent-sdk-api",
        "agent-tool-mcp-gateway",
        "multi-channel-agent-gateway",
        "agent-ui-tui-desktop",
        "agent-skills-plugins",
        "background-agent-scheduler",
        "agent-distribution-release",
        "agent-evals-quality"
      ]
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "expected": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "risk": {
      "type": "string"
    },
    "risk_domains": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_gates": {
      "type": "array",
      "items": {
        "enum": [
          "static",
          "unit",
          "property-fuzz",
          "contract-protocol",
          "fake-integration",
          "runtime-e2e",
          "ui-interaction",
          "live-provider",
          "stress-concurrency",
          "distribution-release",
          "semantic-eval",
          "review"
        ]
      }
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1
    },
    "status": {
      "enum": [
        "planned",
        "running",
        "passed",
        "failed",
        "blocked",
        "exhausted",
        "waived",
        "skipped",
        "needs-review"
      ]
    },
    "surface": {
      "enum": [
        "cli-stream",
        "tui",
        "webui",
        "desktop-gui",
        "browser-automation",
        "channel-ui",
        "eval-ui"
      ]
    }
  },
  "additionalProperties": true
}
