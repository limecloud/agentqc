{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://limecloud.github.io/agentqc/schemas/qc-plan.schema.json",
  "title": "Agent QC Plan",
  "type": "object",
  "required": [
    "schema_version",
    "id",
    "project_profiles",
    "risk_level",
    "required_gates",
    "cases",
    "evidence_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "0.4.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "target_project": {
      "type": "string"
    },
    "project_profiles": {
      "type": "array",
      "items": {
        "enum": [
          "agent-runtime-cli",
          "agent-sdk-api",
          "agent-tool-mcp-gateway",
          "multi-channel-agent-gateway",
          "agent-ui-tui-desktop",
          "agent-skills-plugins",
          "background-agent-scheduler",
          "agent-distribution-release",
          "agent-evals-quality"
        ]
      },
      "minItems": 1
    },
    "risk_level": {
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "risk_domains": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_gates": {
      "type": "array",
      "items": {
        "enum": [
          "static",
          "unit",
          "property-fuzz",
          "contract-protocol",
          "fake-integration",
          "runtime-e2e",
          "ui-interaction",
          "live-provider",
          "stress-concurrency",
          "distribution-release",
          "semantic-eval",
          "review"
        ]
      },
      "minItems": 1
    },
    "cases": {
      "type": "array",
      "items": {
        "$ref": "qc-case.schema.json"
      },
      "minItems": 1
    },
    "evidence_policy": {
      "type": "string",
      "minLength": 1
    },
    "waiver_policy": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
