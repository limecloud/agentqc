{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://limecloud.github.io/agentqc/schemas/qc-benchmark.schema.json",
  "title": "Agent QC Benchmark Experiment",
  "description": "Portable benchmark experiment shape for hill-climbing agent runtimes after evidence-driven QC.",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "id",
    "target_project",
    "purpose",
    "dataset",
    "configurations",
    "tasks",
    "trials",
    "metrics",
    "decision_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "0.5.0"
    },
    "id": {
      "type": "string",
      "minLength": 1
    },
    "target_project": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "dataset": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "version",
        "source",
        "selection_policy"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "selection_policy": {
          "type": "string",
          "minLength": 1
        },
        "frozen_at": {
          "type": "string"
        },
        "harbor": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "local_path": {
              "type": "string"
            },
            "registry_ref": {
              "type": "string"
            },
            "registry_path": {
              "type": "string"
            },
            "frozen_hash": {
              "type": "string"
            },
            "metrics_ref": {
              "type": "string"
            }
          }
        },
        "task_selection": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "count": {
              "type": "integer",
              "minimum": 1
            },
            "strata": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "exclusions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "hypothesis": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "change_id": {
          "type": "string"
        },
        "one_variable_changed": {
          "type": "string"
        },
        "expected_improvement": {
          "type": "string"
        },
        "rollback_rule": {
          "type": "string"
        }
      }
    },
    "configurations": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "role"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "role": {
            "enum": [
              "baseline",
              "candidate",
              "control"
            ]
          },
          "runtime_version": {
            "type": "string"
          },
          "model_profile": {
            "type": "string"
          },
          "prompt_profile": {
            "type": "string"
          },
          "tool_profile": {
            "type": "string"
          },
          "context_policy": {
            "type": "string"
          },
          "agent_profile": {
            "type": "string"
          },
          "harbor_run": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "command": {
                "type": "string"
              },
              "agent": {
                "type": "string"
              },
              "model": {
                "type": "string"
              },
              "env_overrides": {
                "type": "object",
                "additionalProperties": true
              },
              "job_ref": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "id",
          "instruction_ref",
          "verifier",
          "required_gates",
          "required_evidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "project_profile": {
            "type": "string"
          },
          "surface": {
            "type": "string"
          },
          "instruction_ref": {
            "type": "string",
            "minLength": 1
          },
          "verifier": {
            "type": "string",
            "minLength": 1
          },
          "reward_paths": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "required_gates": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "required_evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "harbor_task": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "task_dir": {
                "type": "string"
              },
              "task_toml_ref": {
                "type": "string"
              },
              "environment_ref": {
                "type": "string"
              },
              "tests_ref": {
                "type": "string"
              },
              "solution_ref": {
                "type": "string"
              },
              "multi_step": {
                "type": "boolean"
              },
              "artifacts": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "environment": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "os": {
                "type": "string"
              },
              "sandbox": {
                "type": "string"
              },
              "timeout_sec": {
                "type": "number"
              },
              "cpus": {
                "type": "number"
              },
              "memory_mb": {
                "type": "integer"
              },
              "allow_internet": {
                "type": "boolean"
              }
            }
          },
          "allowed_mutations": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "verifier_contract": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "kind": {
                "enum": [
                  "deterministic",
                  "rewardkit",
                  "judge",
                  "human-review",
                  "mixed"
                ]
              },
              "isolated_environment": {
                "type": "boolean"
              },
              "reward_ref": {
                "type": "string"
              },
              "reward_details_ref": {
                "type": "string"
              },
              "criterion_refs": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "oracle_sanity_check_ref": {
                "type": "string"
              }
            }
          },
          "trajectory_contract": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "schema": {
                "type": "string"
              },
              "ref": {
                "type": "string"
              },
              "required_fields": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "trials": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": true,
        "required": [
          "trial_id",
          "task_id",
          "configuration_id",
          "status",
          "evidence_refs"
        ],
        "properties": {
          "trial_id": {
            "type": "string",
            "minLength": 1
          },
          "task_id": {
            "type": "string",
            "minLength": 1
          },
          "configuration_id": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": [
              "passed",
              "failed",
              "blocked",
              "exhausted",
              "needs-review",
              "skipped"
            ]
          },
          "reward": {
            "type": "number"
          },
          "duration_ms": {
            "type": "integer",
            "minimum": 0
          },
          "trajectory_ref": {
            "type": "string"
          },
          "reward_details_ref": {
            "type": "string"
          },
          "evidence_refs": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "attempt": {
            "type": "integer",
            "minimum": 1
          },
          "job_ref": {
            "type": "string"
          },
          "harbor_trial_ref": {
            "type": "string"
          },
          "artifact_manifest_ref": {
            "type": "string"
          },
          "reward_ref": {
            "type": "string"
          },
          "failure_category": {
            "type": "string"
          },
          "seed": {
            "type": [
              "integer",
              "string"
            ]
          },
          "runtime_correlation": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "sessionId": {
                "type": "string"
              },
              "threadId": {
                "type": "string"
              },
              "turnId": {
                "type": "string"
              },
              "taskId": {
                "type": "string"
              },
              "runId": {
                "type": "string"
              },
              "traceId": {
                "type": "string"
              }
            }
          },
          "cost": {
            "type": "object",
            "additionalProperties": true,
            "properties": {
              "tokens": {
                "type": "integer",
                "minimum": 0
              },
              "cost_usd": {
                "type": "number",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "primary"
      ],
      "properties": {
        "primary": {
          "type": "string",
          "minLength": 1
        },
        "secondary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "noise_policy": {
          "type": "string"
        },
        "custom_metric_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "comparison_ref": {
          "type": "string"
        }
      }
    },
    "decision_policy": {
      "type": "string",
      "minLength": 1
    },
    "decision": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "outcome": {
          "enum": [
            "promote",
            "promote-with-monitoring",
            "hold",
            "revert",
            "blocked",
            "needs-review"
          ]
        },
        "reason": {
          "type": "string"
        },
        "remaining_risks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "p0_qc_gate_regression_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
