{
  "name": "agentqc-standard",
  "version": "0.2.0",
  "type": "module",
  "description": "Portable Agent QC standard for evidence-driven testing of agent runtimes, tools, gateways, UI, skills, SDKs, and distributions.",
  "homepage": "https://limecloud.github.io/agentqc/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/limecloud/agentqc.git"
  },
  "license": "UNLICENSED",
  "keywords": [
    "agent",
    "qc",
    "testing",
    "evaluation",
    "llm",
    "standard",
    "evidence",
    "qcloop"
  ],
  "engines": {
    "node": ">=18.20.0"
  },
  "files": [
    "llm.txt",
    "llm-full.txt",
    "llms.txt",
    "llms-full.txt",
    "docs/public/llm.txt",
    "docs/public/llm-full.txt",
    "docs/public/llms.txt",
    "docs/public/llms-full.txt",
    "docs/public/examples/",
    "docs/public/schemas/",
    "docs/en/",
    "docs/zh/",
    "README.md",
    "CHANGELOG.md",
    "RELEASE_NOTES.md"
  ],
  "scripts": {
    "dev": "vitepress dev docs",
    "build": "vitepress build docs",
    "preview": "vitepress preview docs",
    "check:schemas": "node scripts/validate-examples.mjs",
